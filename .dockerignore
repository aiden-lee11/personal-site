# Keep the build context small. The Dockerfile builds the web app from source;
# the compiler ships as prebuilt artifacts vendored under compiler-bin/ (built
# by the private repo's build-binaries workflow — see compiler-bin/README.md),
# which are copied into /opt/compiler as-is.
**/node_modules
**/.next
**/.turbo
**/out
site/next-env.d.ts

# VCS / editor / OS
.git
.gitignore
**/.DS_Store
**/*.log
.vscode
.idea

# Repo scaffolding not needed in the image
.claude
sandbox
scratchpad
tmp
write-up.md
